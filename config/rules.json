  "_scoring_engine_meta": {
    "description": "底层评分引擎配置——四大防线机制驱动。所有指标的原始业务值经此引擎转换为0-100标准分。",
    "version": "v3.0",
    "四大防线机制": {
      "1_红线乘数_VetoMultiplier": "任一 is_veto=True 的指标得分为0 → 模块总分直接归零，防止优势指标'加权洗白'",
      "2_平滑插值_LinearInterpolation": "在[及格线, 优秀线]区间内使用 np.interp 线性渐变，消灭断崖式阶梯阈值",
      "3_数据缺失惩罚_DataMissing": "关键字段为 null/NaN 时返回 DATA_MISSING 标志，该指标计0分，前端渲染灰色 N/A",
      "4_成熟度时间豁免_TimeDecayExemption": "新开工<exempt_days天的项目，产值转化率等履约指标返回 EXEMPT，赋予默认稳健分"
    },
    "评分类型说明": {
      "direct_linear": "值→分直接映射，阈值区间内线性插值。阈值已包含最终得分，代码不额外反转。高值优→高分(如产值转化率)、高值劣→低分(如风险占比)均在阈值配置中体现",
      "direct_step": "值→分直接映射，阶梯式打分。阈值已包含最终得分，代码不额外反转。0次违规→100分、≥1次→0分等逻辑直接在阈值中编码",
      "composite": "复合指标，由多个子指标加权合成"
    }
  },
